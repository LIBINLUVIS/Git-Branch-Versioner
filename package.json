{
  "name": "git-branch-versioner",
  "displayName": "Git Branch Versioner",
  "description": "Canvas-based Git branch manager",
  "version": "0.0.1",
  "engines": {
    "vscode": "^1.86.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [],
  "main": "./dist/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "gitBranchVersioner",
          "title": "Git Branch Versioner",
          "icon": "resources/icon.svg"
        }
      ]
    },
    "views": {
      "gitBranchVersioner": [
        {
          "id": "gitBranchVersioner.welcome",
          "name": "Branch Canvas",
          "type": "webview",
          "visibility": "visible"
        }
      ]
    },
    "commands": [
      {
        "command": "git-branch-versioner.openCanvas",
        "title": "Open Branch Versioner Canvas",
        "icon": "resources/icon.svg"
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "git-branch-versioner.openCanvas",
          "when": "view == gitBranchVersioner.welcome",
          "group": "navigation"
        }
      ]
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run package",
    "compile": "tsc -p ./",
    "watch": "npm-run-all -p watch:*",
    "watch:ext": "tsc -watch -p ./",
    "watch:webview": "cd webview-ui && npm run build -- --watch",
    "package": "npm run build:webview && esbuild ./src/extension.ts --bundle --outfile=dist/extension.js --external:vscode --format=cjs --platform=node",
    "build:webview": "cd webview-ui && npm run build"
  },
  "devDependencies": {
    "@types/node": "20.x",
    "@types/vscode": "^1.86.0",
    "esbuild": "^0.20.0",
    "npm-run-all": "^4.1.5",
    "typescript": "^5.3.3"
  },
  "dependencies": {
    "@octokit/rest": "^20.0.2"
  }
}
